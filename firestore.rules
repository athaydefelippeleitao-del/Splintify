rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Track Validation Helper
    function isValidTrack(data) {
      return data.keys().hasAll(['title', 'artist', 'album', 'cover', 'duration', 'genre', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.artist is string && data.artist.size() <= 200
        && data.album is string && data.album.size() <= 200
        && data.cover is string && data.cover.size() <= 1000
        && data.duration is number && data.duration > 0
        && data.genre is string && data.genre.size() <= 100;
    }

    // Artist Validation Helper
    function isValidArtist(data) {
      return data.keys().hasAll(['name', 'genre', 'photo', 'createdAt'])
        && data.name is string && data.name.size() <= 200
        && data.genre is string && data.genre.size() <= 100
        && data.photo is string && data.photo.size() <= 1000;
    }

    // Category Validation Helper
    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'color', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.color is string && data.color.size() <= 100;
    }

    // 1. Tracks Rules
    match /tracks/{trackId} {
      allow read: if true;
      allow create: if isAdmin() && isEmailVerified() && isValidId(trackId) && isValidTrack(incoming());
      allow update: if isAdmin() && isEmailVerified() && isValidId(trackId) && isValidTrack(incoming());
      allow delete: if isAdmin() && isEmailVerified() && isValidId(trackId);
    }

    // 2. Artists Rules
    match /artists/{artistId} {
      allow read: if true;
      allow create: if isAdmin() && isEmailVerified() && isValidId(artistId) && isValidArtist(incoming());
      allow update: if isAdmin() && isEmailVerified() && isValidId(artistId) && isValidArtist(incoming());
      allow delete: if isAdmin() && isEmailVerified() && isValidId(artistId);
    }

    // 3. Categories Rules
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isEmailVerified() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isAdmin() && isEmailVerified() && isValidId(categoryId) && isValidCategory(incoming());
      allow delete: if isAdmin() && isEmailVerified() && isValidId(categoryId);
    }

    // 4. Admins Registry
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
